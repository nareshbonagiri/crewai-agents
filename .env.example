# ===== API KEYS (ADD YOUR OWN - DO NOT COMMIT) =====
# ANTHROPIC_API_KEY=sk-ant-api...
# GOOGLE_API_KEY=...  # For Gemini 4 later
# SERPERDEV_API_KEY=...  # For event system web search

# ===== MODEL CONFIGURATION =====
# MODEL_TYPE: "ollama" (local) or "claude" (API) or "gemini" (Google)
MODEL_TYPE=ollama

# MODEL_NAME for different types:
#   Ollama: tinyllama:latest, neural-chat:latest, phi:latest, mistral:latest, llama3.2:latest
#   Claude: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5-20251001
#   Gemini: gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash
MODEL_NAME=llama3.2:latest

# MODEL_TEMPERATURE: 0 (deterministic) to 1 (creative)
MODEL_TEMPERATURE=0.7

# Verbose level: 0 (minimal), 1 (normal), 2 (verbose)
VERBOSE_LEVEL=2
